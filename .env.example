# --- Slack credentials (https://api.slack.com/apps) ---
# For local dev with DRY_RUN_PINGS=true, the placeholder values below are fine.
# To wire up to a real workspace, fill these in and set DRY_RUN_PINGS=false.
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_SIGNING_SECRET=replace-me
SLACK_CLIENT_ID=replace-me
SLACK_CLIENT_SECRET=replace-me

# --- App ---
DATABASE_URL=sqlite:///./commitbot.db
APP_BASE_URL=http://localhost:8000
SESSION_SECRET=change-me-to-a-long-random-string

# --- Dev flags ---
# When true, the scheduler logs pings to stdout instead of calling Slack.
# Keep this on until your Slack app is wired up — saves you from sending
# accidental pings to a real workspace during dev.
DRY_RUN_PINGS=true
LOG_LEVEL=INFO

# --- Agentic commitment capture ---
# Optional. The agent buffers messages from users who opt in (per-user
# `agent_enabled` flag in the dashboard) and classifies them in batches
# on a schedule. If ANTHROPIC_API_KEY is unset the agent falls back to
# a deterministic stub classifier (good enough for dev + tests; not for
# production).
AGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-haiku-4-5-20251001
# When true, the agent runs harvest + classification but does NOT persist
# any commitments. Use to validate prompts without writing to the DB.
AGENT_DRY_RUN=true
# How often the background sweeper runs (minutes). Each pass picks up
# every buffered message that hasn't been classified yet.
AGENT_SCAN_INTERVAL_MINUTES=30
# Confidence floor — candidates below this are dropped (not persisted).
# 0.0 = accept anything the model returns; 1.0 = nothing ever passes.
AGENT_CONFIDENCE_FLOOR=0.75
# How long an agent-captured commitment shows the inline 'Undo' button
# on the Home tab. After this, the user can still soft-delete it from
# the dashboard but the one-click affordance is retired.
AGENT_UNDO_WINDOW_MINUTES=60
# How long buffered messages live before the prune job removes them.
# Independent of whether they've been classified — we keep recent
# history around in case the user re-enables the agent or asks for a
# manual re-scan.
AGENT_BUFFER_RETENTION_DAYS=7
